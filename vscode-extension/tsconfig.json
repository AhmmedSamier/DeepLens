{
    "compilerOptions": {
        "module": "nodenext",
        "target": "ES2021",
        "outDir": "out",
        "lib": ["ES2021"],
        "sourceMap": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "incremental": true,
        "tsBuildInfoFile": "out/.tsbuildinfo",
        "types": ["node", "vscode", "mocha"]
    },
    "include": ["src/**/*", "../language-server/src/core/**/*"],
    "exclude": ["node_modules", ".vscode-test", "cognitive-lens", "../language-server/src/core/**/*.test.ts"]
}
