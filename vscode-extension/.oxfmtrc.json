{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "semi": true,
    "trailingComma": "all",
    "singleQuote": true,
    "printWidth": 120,
    "tabWidth": 4,
    "useTabs": false,
    "sortPackageJson": false,
    "ignorePatterns": [
        "node_modules",
        "dist",
        "out",
        "build",
        "coverage",
        ".vscode-test",
        "*.vsix",
        "*.log",
        ".eslintcache",
        ".DS_Store",
        "Thumbs.db",
        "bin",
        "obj"
    ]
}
